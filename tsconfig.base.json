{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@freitas-ds/react": ["packages/react/src/index.ts"],
      "@freitas-ds/theme": ["packages/theme/src/index.ts"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  }
}
