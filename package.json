{
  "name": "@freitas-ds/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:plugin && pnpm --filter @freitas-ds/dashboard dev",
    "build": "pnpm -r build",
    "storybook": "pnpm build:plugin && pnpm --filter storybook dev",
    "build:storybook": "pnpm --filter storybook build",
    "build:plugin": "pnpm --filter freitas-ds build",
    "dev:consumer": "pnpm build:plugin && pnpm --filter consumer-vite dev",
    "build:consumer": "pnpm --filter consumer-vite build",
    "typecheck:plugin": "pnpm --filter freitas-ds typecheck",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r run clean",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "pnpm --filter @freitas-ds/react test",
    "test:plugin": "pnpm --filter freitas-ds test",
    "test:watch": "pnpm --filter @freitas-ds/react test:watch",
    "test:coverage": "pnpm --filter @freitas-ds/react test:coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:check": "pnpm check && pnpm typecheck && pnpm test && pnpm test:plugin && pnpm build && pnpm build:consumer && pnpm pack:all",
    "publish:packages": "pnpm release:check && pnpm -r --filter './packages/*' publish",
    "pack:theme": "cd packages/theme && pnpm pack --dry-run",
    "pack:styles": "cd packages/styles && pnpm pack --dry-run",
    "pack:react": "cd packages/react && pnpm pack --dry-run",
    "pack:plugin": "cd packages/tailwind-plugin && pnpm pack --dry-run",
    "pack:all": "pnpm pack:theme && pnpm pack:styles && pnpm pack:react && pnpm pack:plugin",
    "quality": "pnpm check && pnpm typecheck && pnpm test && pnpm build",
    "quality:full": "pnpm check && pnpm typecheck && pnpm test && pnpm build && pnpm build:storybook"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freitaseric/freitas-ds.git"
  },
  "homepage": "https://github.com/freitaseric/freitas-ds#readme",
  "bugs": {
    "url": "https://github.com/freitaseric/freitas-ds/issues"
  },
  "author": {
    "name": "Eric Freitas Sampaio",
    "email": "contato@freitaseric.com",
    "url": "https://freitaseric.com"
  },
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "warn"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0"
  }
}
