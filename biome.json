{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!node_modules",
      "!**/node_modules",
      "!dist",
      "!**/dist",
      "!build",
      "!**/build",
      "!storybook-static",
      "!**/storybook-static",
      "!coverage",
      "!**/coverage",
      "!.turbo",
      "!**/.turbo",
      "!.next",
      "!**/.next"
    ]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 90,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  },
  "css": {
    "assist": {
      "enabled": true
    },
    "parser": {
      "tailwindDirectives": true
    }
  }
}
