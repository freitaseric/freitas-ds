    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "tailwindcss": "^4.3.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
}
