{
  "name": "freitas-ds",
  "version": "0.3.0",
  "description": "Plugin Tailwind CSS v4 oficial do Freitas DS.",
  "keywords": [
    "design-system",
    "tailwindcss",
    "plugin",
    "theme",
    "tokens"
  ],
  "author": {
    "name": "Eric Freitas Sampaio",
    "email": "contato@freitaseric.com",
    "url": "https://freitaseric.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freitaseric/freitas-ds.git",
    "directory": "packages/tailwind-plugin"
  },
  "homepage": "https://github.com/freitaseric/freitas-ds#readme",
  "bugs": {
    "url": "https://github.com/freitaseric/freitas-ds/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react.css": "./dist/react.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm typecheck && pnpm test",
    "build": "tsdown && node scripts/build-react-css.mjs",
    "test": "pnpm build && node scripts/test-import.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "@tailwindcss/node": "^4.3.1",
    "tailwindcss": "^4.3.1",
    "tinyglobby": "^0.2.15",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
}
