{
  "name": "@freitas-ds/theme",
  "version": "0.1.0",
  "description": "Motor de temas e tokens semânticos do Freitas DS.",
  "keywords": [
    "design-system",
    "theme",
    "tokens",
    "css-variables"
  ],
  "author": {
    "name": "Eric Freitas Sampaio",
    "email": "contato@freitaseric.com",
    "url": "https://freitaseric.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freitaseric/freitas-ds.git",
    "directory": "packages/theme"
  },
  "homepage": "https://github.com/freitaseric/freitas-ds#readme",
  "bugs": {
    "url": "https://github.com/freitaseric/freitas-ds/issues"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm typecheck",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome check ."
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
}
